<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>低位株TRADE</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0e1a; --surface: #111827; --surface2: #1a2234;
  --border: #2a3a52; --accent: #00d4ff; --accent2: #00ff9f;
  --warn: #ff6b6b; --gold: #ffd700; --text: #e8f0fe; --muted: #7a8ba0;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body { background: var(--bg); color: var(--text); font-family: 'Noto Sans JP', sans-serif; min-height: 100vh; padding-bottom: 80px; }

.header { background: #0f1c35; border-bottom: 1px solid var(--border); padding: 14px 16px; position: sticky; top: 0; z-index: 100; display: flex; justify-content: space-between; align-items: center; }
.app-title { font-size: 18px; font-weight: 900; } .app-title span { color: var(--accent); }
.date-badge { background: var(--surface2); border: 1px solid var(--border); border-radius: 20px; padding: 4px 12px; font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace; }

.page { display: none; padding: 12px; }
.page.active { display: block; }

.card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 14px; margin-bottom: 10px; }
.card-title { font-size: 11px; font-weight: 700; color: var(--accent); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.form-group { margin-bottom: 10px; }
label { display: block; font-size: 11px; color: var(--muted); font-weight: 700; margin-bottom: 4px; }
input, select, textarea { width: 100%; background: var(--surface2); border: 1.5px solid var(--border); border-radius: 10px; padding: 11px 12px; color: var(--text); font-size: 16px; font-family: 'JetBrains Mono', monospace; -webkit-appearance: none; }
input:focus, select:focus, textarea:focus { outline: none; border-color: var(--accent); }
textarea { font-family: 'Noto Sans JP', sans-serif; font-size: 13px; min-height: 80px; resize: none; line-height: 1.6; }

.score-display { background: var(--surface2); border-radius: 14px; padding: 16px; text-align: center; border: 2px solid var(--border); margin-bottom: 12px; }
.score-num { font-size: 60px; font-weight: 900; font-family: 'JetBrains Mono', monospace; line-height: 1; }
.score-num.s0, .score-num.s1 { color: var(--warn); }
.score-num.s2 { color: var(--gold); }
.score-num.s3, .score-num.s4 { color: var(--accent2); }
.score-verdict { font-size: 13px; font-weight: 700; margin-top: 6px; }

.price-boxes { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 12px; }
.price-box { border-radius: 10px; padding: 10px 6px; text-align: center; border: 1.5px solid; }
.price-box.entry { background: rgba(0,212,255,0.08); border-color: rgba(0,212,255,0.3); }
.price-box.profit { background: rgba(0,255,159,0.08); border-color: rgba(0,255,159,0.3); }
.price-box.loss { background: rgba(255,107,107,0.08); border-color: rgba(255,107,107,0.3); }
.price-box-label { font-size: 9px; color: var(--muted); font-weight: 700; margin-bottom: 3px; }
.price-box-value { font-size: 18px; font-weight: 900; font-family: 'JetBrains Mono', monospace; }
.price-box.entry .price-box-value { color: var(--accent); }
.price-box.profit .price-box-value { color: var(--accent2); }
.price-box.loss .price-box-value { color: var(--warn); }
.price-box-sub { font-size: 9px; color: var(--muted); margin-top: 2px; }

.flags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
.flag { padding: 5px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; border: 1.5px solid; }
.flag.on { background: rgba(0,255,159,0.1); border-color: rgba(0,255,159,0.4); color: var(--accent2); }
.flag.off { background: rgba(122,139,160,0.05); border-color: rgba(122,139,160,0.15); color: var(--muted); }
.flag.excluded { background: rgba(255,107,107,0.1); border-color: rgba(255,107,107,0.4); color: var(--warn); }

.btn-primary { width: 100%; background: linear-gradient(135deg, var(--accent), #0099cc); color: #000; border: none; border-radius: 12px; padding: 15px; font-size: 16px; font-weight: 900; cursor: pointer; margin-bottom: 8px; }
.btn-secondary { width: 100%; background: transparent; color: var(--accent); border: 1.5px solid var(--accent); border-radius: 12px; padding: 12px; font-size: 14px; font-weight: 700; cursor: pointer; }
.btn-warn { width: 100%; background: transparent; color: var(--warn); border: 1.5px solid var(--warn); border-radius: 12px; padding: 12px; font-size: 14px; font-weight: 700; cursor: pointer; margin-top: 8px; }

.record-item { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 12px; margin-bottom: 8px; }
.record-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
.record-code { font-size: 18px; font-weight: 900; font-family: 'JetBrains Mono', monospace; }
.record-name { font-size: 11px; color: var(--muted); }
.score-badge { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 900; font-family: 'JetBrains Mono', monospace; flex-shrink: 0; }
.score-badge.s0, .score-badge.s1 { background: rgba(255,107,107,0.15); color: var(--warn); border: 1.5px solid rgba(255,107,107,0.3); }
.score-badge.s2 { background: rgba(255,215,0,0.15); color: var(--gold); border: 1.5px solid rgba(255,215,0,0.3); }
.score-badge.s3, .score-badge.s4 { background: rgba(0,255,159,0.15); color: var(--accent2); border: 1.5px solid rgba(0,255,159,0.3); }
.badge { display: inline-block; padding: 3px 8px; border-radius: 10px; font-size: 11px; font-weight: 700; }
.badge-win { background: rgba(0,255,159,0.15); color: var(--accent2); border: 1px solid rgba(0,255,159,0.3); }
.badge-lose { background: rgba(255,107,107,0.15); color: var(--warn); border: 1px solid rgba(255,107,107,0.3); }
.badge-pending { background: rgba(122,139,160,0.15); color: var(--muted); border: 1px solid rgba(122,139,160,0.3); }
.badge-excluded { background: rgba(255,107,107,0.1); color: var(--warn); border: 1px solid rgba(255,107,107,0.3); }

.prices-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4px; text-align: center; font-size: 11px; margin-top: 8px; }
.price-item-label { color: var(--muted); margin-bottom: 2px; }
.price-item-val { font-weight: 700; font-family: 'JetBrains Mono', monospace; }

.stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 10px; }
.stat-box { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 12px; text-align: center; }
.stat-label { font-size: 10px; color: var(--muted); font-weight: 700; margin-bottom: 4px; }
.stat-val { font-size: 26px; font-weight: 900; font-family: 'JetBrains Mono', monospace; color: var(--accent); }
.stat-sub { font-size: 10px; color: var(--muted); margin-top: 2px; }

.score-row { display: flex; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--border); }
.score-row:last-child { border-bottom: none; }
.score-pill { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 14px; margin-right: 10px; flex-shrink: 0; }
.bar-wrap { flex: 1; }
.bar-labels { display: flex; justify-content: space-between; font-size: 10px; margin-bottom: 3px; }
.bar-bg { height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 3px; }
.bar-fill.high { background: linear-gradient(90deg, var(--accent2), var(--accent)); }
.bar-fill.mid { background: var(--gold); }
.bar-fill.low { background: var(--warn); }
.score-cnt { font-size: 11px; color: var(--muted); margin-left: 8px; white-space: nowrap; }

.progress-bar { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; margin: 6px 0; }
.progress-fill { height: 100%; background: linear-gradient(90deg, var(--accent2), var(--accent)); border-radius: 2px; }

.bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: var(--surface); border-top: 1px solid var(--border); display: flex; z-index: 100; }
.nav-btn { flex: 1; padding: 10px 4px 6px; text-align: center; border: none; background: none; cursor: pointer; color: var(--muted); font-size: 10px; font-weight: 700; }
.nav-btn.active { color: var(--accent); }
.nav-icon { font-size: 20px; display: block; margin-bottom: 2px; }

.empty { text-align: center; padding: 40px 20px; color: var(--muted); }
.empty .emoji { font-size: 48px; display: block; margin-bottom: 12px; }

.toast { position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--accent2); color: #000; padding: 10px 20px; border-radius: 20px; font-size: 13px; font-weight: 700; opacity: 0; transition: all 0.3s; z-index: 999; white-space: nowrap; pointer-events: none; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

.paste-card { border-color: rgba(0,212,255,0.4); background: linear-gradient(135deg,rgba(0,212,255,0.05),rgba(0,255,159,0.05)); }
.divider { text-align: center; font-size: 11px; color: var(--muted); margin: -2px 0 8px; }
</style>
</head>
<body>

<div class="header">
  <div class="app-title">低位株<span>TRADE</span></div>
  <div class="date-badge" id="todayDate"></div>
</div>

<!-- 入力ページ -->
<div class="page active" id="page-input">
  <div class="card paste-card">
    <div class="card-title" style="color:var(--accent2)">🤖 貼り付け自動入力</div>
    <textarea id="pasteBox" placeholder="GPTのテキストをここに貼り付け&#10;複数銘柄は---で区切る"></textarea>
    <button class="btn-primary" style="margin-top:8px;" onclick="doPaste()">⚡ 自動入力する</button>
  </div>
  <div class="divider">── または手動で入力 ──</div>

  <div class="card">
    <div class="card-title">📋 銘柄情報</div>
    <div class="form-row">
      <div class="form-group"><label>銘柄コード</label><input type="number" id="f_code" inputmode="numeric" placeholder="1234"></div>
      <div class="form-group"><label>日付</label><input type="date" id="f_date"></div>
    </div>
    <div class="form-group"><label>銘柄名</label><input type="text" id="f_name" placeholder="○○工業"></div>
  </div>

  <div class="card">
    <div class="card-title">📊 前日 4値</div>
    <div class="form-row">
      <div class="form-group"><label>始値</label><input type="number" id="f_open" inputmode="decimal" placeholder="180" oninput="calcScore()"></div>
      <div class="form-group"><label>高値</label><input type="number" id="f_high" inputmode="decimal" placeholder="195" oninput="calcScore()"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>安値</label><input type="number" id="f_low" inputmode="decimal" placeholder="175" oninput="calcScore()"></div>
      <div class="form-group"><label>終値</label><input type="number" id="f_close" inputmode="decimal" placeholder="192" oninput="calcScore()"></div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">📈 出来高</div>
    <div class="form-row">
      <div class="form-group"><label>売買代金(千円)</label><input type="number" id="f_vol" inputmode="decimal" placeholder="1343329" oninput="calcScore()"></div>
      <div class="form-group"><label>出来高倍率(倍)</label><input type="number" id="f_volRatio" inputmode="decimal" placeholder="3.5" step="0.1" oninput="calcScore()"></div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">🌙 夜間(JNX/PTS)</div>
    <div class="form-row">
      <div class="form-group"><label>夜間始値</label><input type="number" id="f_nOpen" inputmode="decimal" placeholder="82" oninput="calcScore()"></div>
      <div class="form-group"><label>夜間高値</label><input type="number" id="f_nHigh" inputmode="decimal" placeholder="84.5" oninput="calcScore()"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>夜間安値</label><input type="number" id="f_nLow" inputmode="decimal" placeholder="79" oninput="calcScore()"></div>
      <div class="form-group"><label>夜間終値</label><input type="number" id="f_nClose" inputmode="decimal" placeholder="84.5" oninput="calcScore()"></div>
    </div>
    <div class="form-group"><label>夜間代金(千円)</label><input type="number" id="f_nVol" inputmode="decimal" placeholder="31217" oninput="calcScore()"></div>
  </div>

  <!-- スコア表示 -->
  <div class="score-display" id="scoreDisplay">
    <div style="font-size:11px;color:var(--muted);font-weight:700;letter-spacing:1px;margin-bottom:6px;">SIGNAL SCORE</div>
    <div class="score-num s0" id="scoreNum">—</div>
    <div class="score-verdict" id="scoreVerdict" style="color:var(--muted)">終値を入力してください</div>
  </div>

  <div class="flags" id="flagsArea"></div>

  <div class="price-boxes">
    <div class="price-box entry"><div class="price-box-label">エントリー</div><div class="price-box-value" id="p_entry">—</div><div class="price-box-sub" id="p_entrySub"></div></div>
    <div class="price-box profit"><div class="price-box-label">利確</div><div class="price-box-value" id="p_profit">—</div><div class="price-box-sub" id="p_profitSub"></div></div>
    <div class="price-box loss"><div class="price-box-label">損切</div><div class="price-box-value" id="p_loss">—</div><div class="price-box-sub" id="p_lossSub">-3.5%</div></div>
  </div>

  <button class="btn-primary" onclick="saveRecord()">💾 記録する</button>
  <button class="btn-secondary" onclick="clearForm()">クリア</button>
</div>

<!-- 記録ページ -->
<div class="page" id="page-list">
  <div id="listArea"></div>
</div>

<!-- 結果ページ -->
<div class="page" id="page-result">
  <div class="card paste-card">
    <div class="card-title" style="color:var(--accent2)">🤖 結果貼り付け</div>
    <textarea id="resultPasteBox" placeholder="GPTの結果テキストをここに貼り付け&#10;&#10;銘柄コード：1234&#10;寄り付き：190&#10;高値：200&#10;安値：185&#10;---"></textarea>
    <button class="btn-primary" style="margin-top:8px;" onclick="doResultPaste()">⚡ 結果を自動入力する</button>
  </div>
  <div class="divider">── または個別に入力 ──</div>
  <div id="resultArea"></div>
</div>

<!-- 分析ページ -->
<div class="page" id="page-stats">
  <div class="stat-grid" id="statsGrid"></div>
  <div class="card">
    <div class="card-title">📊 スコア別分析</div>
    <div id="scoreAnalysis"></div>
  </div>
  <div class="card" style="margin-top:10px;">
    <div class="card-title">🔒 データ管理</div>
    <button class="btn-primary" onclick="exportCSV()">📊 CSVダウンロード</button>
    <button class="btn-secondary" onclick="backupData()" style="margin-top:8px;">📋 バックアップをコピー</button>
    <textarea id="restoreBox" placeholder="バックアップテキストをここに貼り付けて復元" style="margin-top:8px;min-height:60px;"></textarea>
    <button class="btn-warn" onclick="restoreData()">🔄 データ復元</button>
    <button class="btn-warn" onclick="dedupeData()" style="margin-top:8px;">🧹 重複削除</button>
  </div>
</div>

<div class="bottom-nav">
  <button class="nav-btn active" onclick="showPage('input',this)"><span class="nav-icon">✏️</span>入力</button>
  <button class="nav-btn" onclick="showPage('list',this)"><span class="nav-icon">📋</span>記録</button>
  <button class="nav-btn" onclick="showPage('result',this)"><span class="nav-icon">🎯</span>結果</button>
  <button class="nav-btn" onclick="showPage('stats',this)"><span class="nav-icon">📊</span>分析</button>
</div>
<div class="toast" id="toast"></div>

<script>
// ========== ストレージ ==========
const STORE_KEY = 'tgk_v3';

function loadRecords() {
  try {
    const d = localStorage.getItem(STORE_KEY);
    if (d) { const p = JSON.parse(d); if (Array.isArray(p)) return p; }
  } catch(e) {}
  return [];
}

function saveAll(records) {
  localStorage.setItem(STORE_KEY, JSON.stringify(records));
}

// ========== 初期化 ==========
const today = new Date();
document.getElementById('todayDate').textContent =
  today.getFullYear() + '/' + String(today.getMonth()+1).padStart(2,'0') + '/' + String(today.getDate()).padStart(2,'0');
document.getElementById('f_date').value = today.toISOString().split('T')[0];

// ========== スコア計算 ==========
function calcScore() {
  const close  = parseFloat(document.getElementById('f_close').value) || 0;
  const open   = parseFloat(document.getElementById('f_open').value) || 0;
  const high   = parseFloat(document.getElementById('f_high').value) || 0;
  const low    = parseFloat(document.getElementById('f_low').value) || 0;
  const vol    = parseFloat(document.getElementById('f_vol').value) || 0;
  const vr     = parseFloat(document.getElementById('f_volRatio').value) || 0;
  const nOpen  = parseFloat(document.getElementById('f_nOpen').value) || 0;
  const nHigh  = parseFloat(document.getElementById('f_nHigh').value) || 0;
  const nClose = parseFloat(document.getElementById('f_nClose').value) || 0;

  if (!close) {
    document.getElementById('scoreNum').textContent = '—';
    document.getElementById('scoreVerdict').textContent = '終値を入力してください';
    document.getElementById('scoreVerdict').style.color = 'var(--muted)';
    document.getElementById('p_entry').textContent = '—';
    document.getElementById('p_profit').textContent = '—';
    document.getElementById('p_loss').textContent = '—';
    document.getElementById('flagsArea').innerHTML = '';
    return;
  }

  const nightRise = nClose > 0 ? (nClose - close) / close : 0;
  const isExcluded = nightRise >= 0.15;

  const flags = [
    { on: low > 0 && (close - low) / low > 0.03, label: '📈 ギャップアップ' },
    { on: open > 0 && close > open, label: '🕯 陽線' },
    { on: vol > 500000, label: '💥 出来高急増' },
    { on: vr >= 5, label: '🔥 前日比' + vr.toFixed(1) + '倍' },
    { on: vr >= 2 && vr < 5, label: '📊 前日比' + vr.toFixed(1) + '倍' },
    { on: nightRise > 0.01 && !isExcluded, label: '🌙 夜間+' + (nightRise*100).toFixed(1) + '%' },
    { on: nHigh > 0 && nOpen > 0 && (nHigh - nOpen)/nOpen > 0.01 && !isExcluded, label: '🚀 夜間強い' },
    { on: high > 0 && nHigh > 0 && nHigh > high, label: '📊 高値更新' },
  ];

  document.getElementById('flagsArea').innerHTML = flags.map(f =>
    '<div class="flag ' + (isExcluded ? 'excluded' : f.on ? 'on' : 'off') + '">' + f.label + '</div>'
  ).join('') + (isExcluded ? '<div class="flag excluded">⚠️ 夜間+15%超・除外</div>' : '');

  if (isExcluded) {
    document.getElementById('scoreNum').textContent = '×';
    document.getElementById('scoreNum').className = 'score-num s0';
    document.getElementById('scoreVerdict').textContent = '夜間過熱 → エントリー禁止';
    document.getElementById('scoreVerdict').style.color = 'var(--warn)';
    document.getElementById('p_entry').textContent = '除外';
    document.getElementById('p_profit').textContent = '—';
    document.getElementById('p_loss').textContent = '—';
    return;
  }

  let score = flags.slice(0,8).filter(f => f.on).length;
  score = Math.min(score, 4);

  document.getElementById('scoreNum').textContent = score;
  document.getElementById('scoreNum').className = 'score-num s' + score;

  const verdicts = ['見送り推奨','シグナル弱い','検討レベル','エントリー有望 ✓','強いシグナル!! ✓✓'];
  const colors = ['var(--muted)','var(--warn)','var(--gold)','var(--accent2)','var(--accent2)'];
  document.getElementById('scoreVerdict').textContent = verdicts[score];
  document.getElementById('scoreVerdict').style.color = colors[score];

  // エントリー計算（PTS終値基準）
  const base = nClose > 0 ? nClose : close;
  const mul = nightRise < 0.05 ? 0.97 : nightRise < 0.10 ? 0.98 : 0.99;
  const entry = Math.round(base * mul);
  const profit = Math.round(entry * 1.04);
  const loss   = Math.round(entry * 0.965);

  document.getElementById('p_entry').textContent  = '¥' + entry;
  document.getElementById('p_profit').textContent = '¥' + profit;
  document.getElementById('p_loss').textContent   = '¥' + loss;
  document.getElementById('p_entrySub').textContent  = 'PTS×' + mul;
  document.getElementById('p_profitSub').textContent = '+4%';
}

// ========== 記録保存 ==========
function saveRecord() {
  const code  = document.getElementById('f_code').value.trim();
  const date  = document.getElementById('f_date').value;
  const close = parseFloat(document.getElementById('f_close').value) || 0;

  if (!code || !close) { showToast('❌ 銘柄コードと終値は必須です'); return; }

  const records = loadRecords();

  // 重複チェック
  const dupIdx = records.findIndex(r => String(r.code) === String(code) && r.date === date);
  if (dupIdx >= 0) {
    if (!confirm(code + '(' + date + ')は既に記録済みです。上書きしますか？')) return;
  }

  const open   = parseFloat(document.getElementById('f_open').value) || 0;
  const high   = parseFloat(document.getElementById('f_high').value) || 0;
  const low    = parseFloat(document.getElementById('f_low').value) || 0;
  const vol    = parseFloat(document.getElementById('f_vol').value) || 0;
  const vr     = parseFloat(document.getElementById('f_volRatio').value) || 0;
  const nOpen  = parseFloat(document.getElementById('f_nOpen').value) || 0;
  const nHigh  = parseFloat(document.getElementById('f_nHigh').value) || 0;
  const nLow   = parseFloat(document.getElementById('f_nLow').value) || 0;
  const nClose = parseFloat(document.getElementById('f_nClose').value) || 0;
  const nVol   = parseFloat(document.getElementById('f_nVol').value) || 0;
  const name   = document.getElementById('f_name').value.trim();

  const nightRise = nClose > 0 ? (nClose - close) / close : 0;
  const isExcluded = nightRise >= 0.15;

  const flagArr = [
    low > 0 && (close - low) / low > 0.03,
    open > 0 && close > open,
    vol > 500000,
    vr >= 5,
    vr >= 2 && vr < 5,
    nightRise > 0.01 && !isExcluded,
    nHigh > 0 && nOpen > 0 && (nHigh - nOpen)/nOpen > 0.01 && !isExcluded,
    high > 0 && nHigh > 0 && nHigh > high,
  ];
  let score = Math.min(flagArr.filter(Boolean).length, 4);

  const base = nClose > 0 ? nClose : close;
  const mul  = nightRise < 0.05 ? 0.97 : nightRise < 0.10 ? 0.98 : 0.99;
  const entry  = Math.round(base * mul);
  const profit = Math.round(entry * 1.04);
  const loss   = Math.round(entry * 0.965);

  const record = {
    id: Date.now(),
    code, date, name,
    open, high, low, close, vol, vr,
    nOpen, nHigh, nLow, nClose, nVol,
    score, entry, profit, loss, isExcluded,
    actualOpen: null, actualHigh: null, actualLow: null,
    result: null, pnl: null
  };

  if (dupIdx >= 0) {
    // 上書き時は結果データを保持
    record.actualOpen = records[dupIdx].actualOpen;
    record.actualHigh = records[dupIdx].actualHigh;
    record.actualLow  = records[dupIdx].actualLow;
    record.result     = records[dupIdx].result;
    record.pnl        = records[dupIdx].pnl;
    records[dupIdx] = record;
  } else {
    records.unshift(record);
  }

  saveAll(records);
  clearForm();
  showToast('✅ 記録しました！');
  renderAll();
}

// ========== フォームクリア ==========
function clearForm() {
  ['f_code','f_name','f_open','f_high','f_low','f_close','f_vol','f_volRatio',
   'f_nOpen','f_nHigh','f_nLow','f_nClose','f_nVol'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('f_date').value = today.toISOString().split('T')[0];
  calcScore();
}

// ========== 貼り付け自動入力 ==========
function doPaste() {
  const text = document.getElementById('pasteBox').value.trim();
  if (!text) { showToast('❌ テキストを入力してください'); return; }

  const blocks = text.split(/\n---+\n?|\n(?=銘柄コード[：:])/);
  let count = 0;

  blocks.forEach(block => {
    block = block.trim();
    if (!block) return;

    const getVal = (keys) => {
      for (const key of keys) {
        const m = block.match(new RegExp(key + '[：:]\\s*([\\d\\.]+)', 'i'));
        if (m) return m[1];
      }
      return '';
    };
    const getName = () => {
      const m = block.match(/銘柄名[：:]\s*(.+)/);
      return m ? m[1].trim() : '';
    };

    const code = getVal(['銘柄コード']);
    if (!code) return;

    document.getElementById('f_code').value      = code;
    document.getElementById('f_name').value      = getName();
    document.getElementById('f_open').value      = getVal(['始値']);
    document.getElementById('f_high').value      = getVal(['高値']);
    document.getElementById('f_low').value       = getVal(['安値']);
    document.getElementById('f_close').value     = getVal(['終値']);
    document.getElementById('f_vol').value       = getVal(['売買代金']);
    document.getElementById('f_volRatio').value  = getVal(['出来高倍率']);
    document.getElementById('f_nOpen').value     = getVal(['夜間始値']);
    document.getElementById('f_nHigh').value     = getVal(['夜間高値']);
    document.getElementById('f_nLow').value      = getVal(['夜間安値']);
    document.getElementById('f_nClose').value    = getVal(['夜間終値']);
    document.getElementById('f_nVol').value      = getVal(['夜間代金']);

    calcScore();

    if (blocks.length > 1) {
      // 複数銘柄は自動保存
      const c = document.getElementById('f_close').value;
      const cd = document.getElementById('f_code').value;
      if (cd && c) {
        saveRecordSilent();
        count++;
      }
    }
  });

  document.getElementById('pasteBox').value = '';

  if (blocks.length > 1) {
    showToast('✅ ' + count + '件を保存しました！');
    renderAll();
  } else {
    showToast('✅ 入力しました！内容確認して💾ボタンで保存');
  }
}

// サイレント保存（貼り付け複数銘柄用）
function saveRecordSilent() {
  const code  = document.getElementById('f_code').value.trim();
  const date  = document.getElementById('f_date').value;
  const close = parseFloat(document.getElementById('f_close').value) || 0;
  if (!code || !close) return;

  const records = loadRecords();
  const dupIdx = records.findIndex(r => String(r.code) === String(code) && r.date === date);

  const open   = parseFloat(document.getElementById('f_open').value) || 0;
  const high   = parseFloat(document.getElementById('f_high').value) || 0;
  const low    = parseFloat(document.getElementById('f_low').value) || 0;
  const vol    = parseFloat(document.getElementById('f_vol').value) || 0;
  const vr     = parseFloat(document.getElementById('f_volRatio').value) || 0;
  const nOpen  = parseFloat(document.getElementById('f_nOpen').value) || 0;
  const nHigh  = parseFloat(document.getElementById('f_nHigh').value) || 0;
  const nLow   = parseFloat(document.getElementById('f_nLow').value) || 0;
  const nClose = parseFloat(document.getElementById('f_nClose').value) || 0;
  const nVol   = parseFloat(document.getElementById('f_nVol').value) || 0;
  const name   = document.getElementById('f_name').value.trim();

  const nightRise = nClose > 0 ? (nClose - close) / close : 0;
  const isExcluded = nightRise >= 0.15;
  const flagArr = [
    low > 0 && (close - low)/low > 0.03, open > 0 && close > open,
    vol > 500000, vr >= 5, vr >= 2 && vr < 5,
    nightRise > 0.01 && !isExcluded,
    nHigh > 0 && nOpen > 0 && (nHigh-nOpen)/nOpen > 0.01 && !isExcluded,
    high > 0 && nHigh > 0 && nHigh > high,
  ];
  let score = Math.min(flagArr.filter(Boolean).length, 4);
  const base = nClose > 0 ? nClose : close;
  const mul  = nightRise < 0.05 ? 0.97 : nightRise < 0.10 ? 0.98 : 0.99;
  const entry = Math.round(base * mul);
  const profit = Math.round(entry * 1.04);
  const loss   = Math.round(entry * 0.965);

  const rec = {
    id: dupIdx >= 0 ? records[dupIdx].id : Date.now(),
    code, date, name, open, high, low, close, vol, vr,
    nOpen, nHigh, nLow, nClose, nVol,
    score, entry, profit, loss, isExcluded,
    actualOpen: dupIdx >= 0 ? records[dupIdx].actualOpen : null,
    actualHigh: dupIdx >= 0 ? records[dupIdx].actualHigh : null,
    actualLow:  dupIdx >= 0 ? records[dupIdx].actualLow  : null,
    result:     dupIdx >= 0 ? records[dupIdx].result     : null,
    pnl:        dupIdx >= 0 ? records[dupIdx].pnl        : null,
  };

  if (dupIdx >= 0) records[dupIdx] = rec;
  else records.unshift(rec);
  saveAll(records);
}

// ========== 結果貼り付け ==========
function doResultPaste() {
  const text = document.getElementById('resultPasteBox').value.trim();
  if (!text) { showToast('❌ テキストを入力してください'); return; }

  const records = loadRecords();
  let updated = 0;

  // ---で分割
  const blocks = text.split(/\n?---+\n?/).map(b => b.trim()).filter(b => b.length > 0);

  blocks.forEach(block => {
    const getVal = (keys) => {
      for (const key of keys) {
        const m = block.match(new RegExp(key + '[：:]\\s*([\\d\\.]+)', 'i'));
        if (m) return parseFloat(m[1]);
      }
      return null;
    };

    const codeMatch = block.match(/銘柄コード[：:]\s*(\d+)/);
    if (!codeMatch) return;
    const codeStr = codeMatch[1].trim();

    const aOpen = getVal(['寄り付き','実際の寄り付き']);
    const aHigh = getVal(['高値','当日高値']);
    const aLow  = getVal(['安値','当日安値']);

    if (aOpen === null && aHigh === null && aLow === null) return;

    // 同じコードの全レコードを更新
    records.forEach((r, idx) => {
      if (String(r.code).trim() !== codeStr) return;

      if (aOpen !== null) records[idx].actualOpen = aOpen;
      if (aHigh !== null) records[idx].actualHigh = aHigh;
      if (aLow  !== null) records[idx].actualLow  = aLow;

      // 結果判定
      const checkLow = records[idx].actualLow || records[idx].actualOpen;
      if (records[idx].actualHigh && records[idx].actualHigh >= records[idx].profit) {
        records[idx].result = '勝';
        records[idx].pnl = ((records[idx].profit - records[idx].entry) / records[idx].entry * 100).toFixed(1);
      } else if (checkLow && checkLow <= records[idx].loss) {
        records[idx].result = '負';
        records[idx].pnl = ((records[idx].loss - records[idx].entry) / records[idx].entry * 100).toFixed(1);
      } else {
        records[idx].result = null;
        records[idx].pnl = null;
      }
      updated++;
    });
  });

  if (updated > 0) {
    saveAll(records);
    document.getElementById('resultPasteBox').value = '';
    showToast('✅ ' + updated + '件の結果を更新しました！');
    renderAll();
  } else {
    showToast('❌ 一致する記録が見つかりません');
  }
}

// ========== 手動結果更新 ==========
function updateField(id, field, val) {
  const records = loadRecords();
  const idx = records.findIndex(r => r.id === id);
  if (idx < 0) return;

  records[idx][field] = parseFloat(val) || null;

  const r = records[idx];
  const checkLow = r.actualLow || r.actualOpen;
  if (r.actualHigh && r.actualHigh >= r.profit) {
    records[idx].result = '勝';
    records[idx].pnl = ((r.profit - r.entry) / r.entry * 100).toFixed(1);
  } else if (checkLow && checkLow <= r.loss) {
    records[idx].result = '負';
    records[idx].pnl = ((r.loss - r.entry) / r.entry * 100).toFixed(1);
  } else {
    records[idx].result = null;
    records[idx].pnl = null;
  }

  saveAll(records);
  showToast('✅ 保存しました');
  renderAll();
}

// ========== 削除 ==========
function deleteRec(id) {
  if (!confirm('削除しますか？')) return;
  const records = loadRecords().filter(r => r.id !== id);
  saveAll(records);
  showToast('🗑 削除しました');
  renderAll();
}

// ========== 描画 ==========
function renderAll() {
  renderList();
  renderResult();
  renderStats();
}

function resultBadge(r) {
  if (r.isExcluded) return '<span class="badge badge-excluded">⚠️ 除外</span>';
  if (r.result === '勝') return '<span class="badge badge-win">🟢 勝</span>';
  if (r.result === '負') return '<span class="badge badge-lose">🔴 負</span>';
  return '<span class="badge badge-pending">⚪ 未</span>';
}

function renderList() {
  const records = loadRecords();
  const el = document.getElementById('listArea');
  if (!records.length) {
    el.innerHTML = '<div class="empty"><span class="emoji">📭</span>まだ記録がありません</div>';
    return;
  }
  el.innerHTML = records.map(r => `
    <div class="record-item">
      <div class="record-header">
        <div>
          <div class="record-code">${r.code} <span class="record-name">${r.name||''}</span></div>
          <div style="margin-top:4px;">${resultBadge(r)}</div>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <div class="score-badge s${r.score}">${r.score}</div>
          <button onclick="deleteRec(${r.id})" style="background:transparent;border:1px solid var(--warn);color:var(--warn);border-radius:8px;padding:5px 10px;font-size:11px;font-weight:700;cursor:pointer;">削除</button>
        </div>
      </div>
      <div class="prices-grid">
        <div><div class="price-item-label">エントリー</div><div class="price-item-val" style="color:var(--accent)">¥${r.entry}</div></div>
        <div><div class="price-item-label">利確</div><div class="price-item-val" style="color:var(--accent2)">¥${r.profit}</div></div>
        <div><div class="price-item-label">損切</div><div class="price-item-val" style="color:var(--warn)">¥${r.loss}</div></div>
      </div>
      <div style="font-size:10px;color:var(--muted);margin-top:6px;">${r.date} ／ 終値¥${r.close} ／ 夜間終値¥${r.nClose||'—'}</div>
    </div>
  `).join('');
}

function renderResult() {
  const records = loadRecords();
  const el = document.getElementById('resultArea');
  if (!records.length) {
    el.innerHTML = '<div class="empty"><span class="emoji">🎯</span>記録がありません</div>';
    return;
  }
  el.innerHTML = records.map(r => `
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
        <div>
          <div style="font-size:17px;font-weight:900;font-family:'JetBrains Mono',monospace;">${r.code} <span style="font-size:12px;color:var(--muted);font-family:'Noto Sans JP',sans-serif;">${r.name||''}</span></div>
          <div style="margin-top:3px;">${resultBadge(r)}</div>
        </div>
        <div class="score-badge s${r.score}">${r.score}</div>
      </div>
      <div class="prices-grid" style="margin-bottom:10px;">
        <div><div class="price-item-label">エントリー</div><div class="price-item-val" style="color:var(--accent)">¥${r.entry}</div></div>
        <div><div class="price-item-label">利確</div><div class="price-item-val" style="color:var(--accent2)">¥${r.profit}</div></div>
        <div><div class="price-item-label">損切</div><div class="price-item-val" style="color:var(--warn)">¥${r.loss}</div></div>
      </div>
      <div class="form-row" style="margin-bottom:8px;">
        <div><label>寄り付き</label><input type="number" inputmode="decimal" placeholder="190" value="${r.actualOpen||''}" onchange="updateField(${r.id},'actualOpen',this.value)"></div>
        <div><label>当日高値</label><input type="number" inputmode="decimal" placeholder="200" value="${r.actualHigh||''}" onchange="updateField(${r.id},'actualHigh',this.value)"></div>
      </div>
      <div class="form-group"><label>当日安値（損切判定用）</label><input type="number" inputmode="decimal" placeholder="185" value="${r.actualLow||''}" onchange="updateField(${r.id},'actualLow',this.value)"></div>
    </div>
  `).join('');
}

function renderStats() {
  const records = loadRecords();
  const all     = records.filter(r => !r.isExcluded);
  const done    = all.filter(r => r.result === '勝' || r.result === '負');
  const wins    = done.filter(r => r.result === '勝');
  const losses  = done.filter(r => r.result === '負');
  const pending = all.filter(r => !r.result);
  const excl    = records.filter(r => r.isExcluded);
  const wr      = done.length ? Math.round(wins.length / done.length * 100) : null;
  const wrColor = wr === null ? 'var(--accent)' : wr >= 60 ? 'var(--accent2)' : wr < 40 ? 'var(--warn)' : 'var(--gold)';

  document.getElementById('statsGrid').innerHTML = `
    <div class="stat-box">
      <div class="stat-label">総記録数</div>
      <div class="stat-val">${records.length}</div>
      <div class="stat-sub">${done.length}決着 / ${pending.length}未 / ${excl.length}除外</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">全体勝率</div>
      <div class="stat-val" style="color:${wrColor}">${wr !== null ? wr + '%' : '—'}</div>
      <div class="stat-sub">${wins.length}勝 ${losses.length}負 ${pending.length}未達</div>
    </div>
  `;

  // 自動最適化進捗
  const pct = Math.min(done.length / 30 * 100, 100);
  const MIN_DATA = 30;

  let statsHtml = '';
  if (done.length < MIN_DATA) {
    statsHtml += `<div style="font-size:11px;color:var(--muted);margin-bottom:8px;">🔒 自動最適化まで ${MIN_DATA - done.length}件</div>
    <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>`;
  }

  for (let s = 4; s >= 0; s--) {
    const grp   = all.filter(r => r.score === s);
    const dGrp  = grp.filter(r => r.result === '勝' || r.result === '負');
    const gW    = dGrp.filter(r => r.result === '勝');
    const gL    = dGrp.filter(r => r.result === '負');
    const gP    = grp.filter(r => !r.result);
    if (!grp.length) continue;
    const wpct  = dGrp.length ? Math.round(gW.length / dGrp.length * 100) : 0;
    const bc    = s >= 3 ? 'high' : s === 2 ? 'mid' : 'low';
    statsHtml += `
      <div class="score-row">
        <div class="score-pill s${s}" style="${s>=3?'background:rgba(0,255,159,0.15);color:var(--accent2)':s===2?'background:rgba(255,215,0,0.15);color:var(--gold)':'background:rgba(255,107,107,0.15);color:var(--warn)'}">${s}</div>
        <div class="bar-wrap">
          <div class="bar-labels">
            <span style="font-weight:700">${dGrp.length ? wpct + '%' : '未集計'}</span>
            <span style="color:var(--muted);font-size:10px;">${gW.length}勝${gL.length}負${gP.length}未</span>
          </div>
          <div class="bar-bg"><div class="bar-fill ${bc}" style="width:${wpct}%"></div></div>
        </div>
        <div class="score-cnt">${grp.length}件</div>
      </div>`;
  }
  document.getElementById('scoreAnalysis').innerHTML = statsHtml || '<div style="color:var(--muted);font-size:12px;padding:12px 0">記録がありません</div>';
}

// ========== データ管理 ==========
function backupData() {
  const records = loadRecords();
  if (!records.length) { showToast('❌ データがありません'); return; }
  const txt = 'TGKV3:' + JSON.stringify(records);
  navigator.clipboard.writeText(txt).then(() => {
    showToast('✅ ' + records.length + '件をコピーしました');
  }).catch(() => {
    document.getElementById('restoreBox').value = txt;
    showToast('✅ 下のテキストをコピーして保存してください');
  });
}

function restoreData() {
  const txt = document.getElementById('restoreBox').value.trim();
  if (!txt) { showToast('❌ テキストを貼り付けてください'); return; }
  try {
    const json = txt.startsWith('TGKV3:') ? txt.slice(6) : txt;
    const data = JSON.parse(json);
    if (!Array.isArray(data)) throw new Error();
    saveAll(data);
    document.getElementById('restoreBox').value = '';
    showToast('✅ ' + data.length + '件を復元しました');
    renderAll();
  } catch(e) {
    showToast('❌ 復元失敗。正しいバックアップか確認してください');
  }
}

function dedupeData() {
  const records = loadRecords();
  const seen = new Set();
  const clean = records.filter(r => {
    const key = r.code + '_' + r.date;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
  const removed = records.length - clean.length;
  if (!removed) { showToast('✅ 重複データなし'); return; }
  if (confirm(removed + '件の重複を削除しますか？')) {
    saveAll(clean);
    showToast('🧹 ' + removed + '件削除しました');
    renderAll();
  }
}

function exportCSV() {
  const records = loadRecords();
  if (!records.length) { showToast('❌ データがありません'); return; }
  const h = ['日付','コード','銘柄名','始値','高値','安値','終値','売買代金','倍率','夜間始','夜間高','夜間安','夜間終','夜間代金','スコア','エントリー','利確','損切','寄付','当日高','当日安','結果','損益率'];
  const rows = records.map(r => [r.date,r.code,r.name||'',r.open,r.high,r.low,r.close,r.vol,r.vr,r.nOpen,r.nHigh,r.nLow,r.nClose,r.nVol,r.score,r.entry,r.profit,r.loss,r.actualOpen||'',r.actualHigh||'',r.actualLow||'',r.result||'',r.pnl||'']);
  const csv = '\uFEFF' + [h,...rows].map(r=>r.join(',')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download = '低位株_' + today.toISOString().split('T')[0] + '.csv';
  a.click();
  showToast('📥 ダウンロード中...');
}

// ========== ページ切り替え ==========
function showPage(name, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  btn.classList.add('active');
  if (name === 'list') renderList();
  if (name === 'result') renderResult();
  if (name === 'stats') renderStats();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ========== 起動 ==========
const startRecords = loadRecords();
if (startRecords.length > 0) showToast('✅ ' + startRecords.length + '件読み込みました');
renderAll();
